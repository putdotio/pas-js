{
  "name": "@putdotio/pas-js",
  "version": "2.9.0",
  "description": "Browser analytics client for the put.io Analytics System.",
  "keywords": [
    "analytics",
    "pas",
    "put.io",
    "putio"
  ],
  "homepage": "https://github.com/putdotio/pas-js",
  "bugs": {
    "url": "https://github.com/putdotio/pas-js/issues"
  },
  "license": "MIT",
  "author": "put.io <devs@put.io>",
  "repository": {
    "type": "git",
    "url": "https://github.com/putdotio/pas-js.git"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "default": "./dist/index.js"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "vp pack",
    "check": "vp check .",
    "clean": "rm -rf coverage dist",
    "coverage": "vp test --coverage",
    "dev": "vp pack --watch",
    "prepack": "vp pack",
    "test": "vp test",
    "test:consumer": "vp pack && node ./scripts/consumer-smoke.mjs",
    "verify": "vp check . && vp pack && vp test && vp test --coverage"
  },
  "dependencies": {
    "js-cookie": "^3.0.7",
    "query-string": "^9.3.1",
    "rxjs": "^7.8.2",
    "uuid": "^14.0.0"
  },
  "devDependencies": {
    "@putdotio/prettier-config": "^2.0.0",
    "@types/js-cookie": "^3.0.6",
    "@types/node": "^25.9.1",
    "@types/query-string": "^6",
    "@types/uuid": "^11.0.0",
    "@vitest/coverage-v8": "4.1.7",
    "jsdom": "^29.1.1",
    "typescript": "^6.0.3",
    "vite-plus": "^0.1.20",
    "xhr-mock": "^2.5.1"
  },
  "prettier": "@putdotio/prettier-config",
  "engines": {
    "node": ">=24.14.0"
  },
  "packageManager": "pnpm@11.0.0"
}
